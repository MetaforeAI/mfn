{
  "description": "MFN Phase 2 Performance Validation Configuration",
  "version": "1.0.0",
  
  "performance_targets": {
    "layer3_http_baseline_ms": 200.0,
    "layer3_unix_target_ms": 0.16,
    "system_qps_baseline": 100,
    "system_qps_target": 5000,
    "success_rate_minimum": 0.95,
    "error_rate_maximum": 0.05
  },
  
  "test_configurations": {
    "regression_test": {
      "protocol": "unix_socket",
      "target_qps": 500,
      "test_duration_seconds": 60,
      "ramp_up_seconds": 10,
      "concurrent_connections": 25,
      "request_timeout_ms": 2000,
      "warmup_requests": 20
    },
    
    "load_test": {
      "protocol": "unix_socket",
      "qps_levels": [100, 500, 1000, 2000, 3000, 5000],
      "test_duration_seconds": 90,
      "ramp_up_seconds": 15,
      "max_concurrent_connections": 100,
      "request_timeout_ms": 1000,
      "warmup_requests": 30
    },
    
    "comparison_test": {
      "protocols": ["http", "unix_socket", "binary"],
      "target_qps": 1000,
      "test_duration_seconds": 60,
      "ramp_up_seconds": 10,
      "concurrent_connections": 50,
      "request_timeout_ms": 2000,
      "warmup_requests": 20
    },
    
    "integration_test": {
      "protocol": "unix_socket",
      "target_qps": 500,
      "test_duration_seconds": 120,
      "ramp_up_seconds": 20,
      "concurrent_connections": 30,
      "request_timeout_ms": 10000,
      "warmup_requests": 15,
      "layer_specific": {
        "layer1": {"memory_size": 10000},
        "layer2": {"reservoir_size": 1024},
        "layer3": {"max_depth": 3, "max_results": 10},
        "layer4": {"context_window": 50}
      }
    }
  },
  
  "monitoring": {
    "alert_thresholds": {
      "latency_threshold_ms": 1.0,
      "qps_threshold": 4000,
      "error_rate_threshold": 0.05,
      "success_rate_threshold": 0.95,
      "memory_threshold_mb": 1000,
      "cpu_threshold_percent": 80,
      "trend_window_minutes": 30,
      "alert_cooldown_minutes": 5
    },
    
    "monitoring_interval_seconds": 30,
    "health_check_interval_seconds": 60,
    "trend_analysis_points": 10
  },
  
  "migration": {
    "rollback_triggers": {
      "latency_regression_threshold": 1.5,
      "qps_degradation_threshold": 0.8,
      "error_rate_threshold": 0.05,
      "success_rate_threshold": 0.90
    },
    
    "validation_criteria": {
      "target_latency_ms": 0.16,
      "target_qps": 5000,
      "minimum_success_rate": 0.99,
      "validation_duration_seconds": 300,
      "canary_percentage": 0.1,
      "timeout_minutes_per_step": 60
    },
    
    "backup_retention_hours": 24,
    "step_timeout_minutes": 90
  },
  
  "service_endpoints": {
    "layer1": {
      "http": "http://localhost:8080",
      "unix": "/tmp/mfn_layer1.sock"
    },
    "layer2": {
      "http": "http://localhost:8081", 
      "unix": "/tmp/mfn_layer2.sock"
    },
    "layer3": {
      "http": "http://localhost:8082",
      "unix": "/tmp/mfn_layer3.sock"
    },
    "layer4": {
      "http": "http://localhost:8084",
      "unix": "/tmp/mfn_layer4.sock"
    }
  },
  
  "database": {
    "path": "/tmp/mfn_performance_validation.db",
    "backup_interval_hours": 6,
    "retention_days": 30
  },
  
  "logging": {
    "level": "INFO",
    "file": "/tmp/mfn_performance_validation.log",
    "max_file_size_mb": 100,
    "backup_count": 5
  },
  
  "notifications": {
    "enabled": true,
    "channels": ["discord", "log"],
    "discord": {
      "webhook_url": "",
      "channel_id": "",
      "mention_on_critical": true
    },
    "email": {
      "enabled": false,
      "smtp_server": "",
      "recipients": []
    }
  },
  
  "system_requirements": {
    "minimum_cpu_cores": 4,
    "minimum_memory_gb": 8,
    "minimum_disk_space_gb": 10,
    "network_bandwidth_mbps": 1000
  }
}