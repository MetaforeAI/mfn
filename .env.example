# MFN Environment Configuration Template
# Copy this file to .env and configure with your actual values
# NEVER commit .env to version control

# ============================================================================
# CRITICAL SECURITY SETTINGS
# ============================================================================

# Grafana Admin Password
# IMPORTANT: Change this before deployment!
# Generate strong password: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=changeme

# Dashboard Authentication (optional)
# Set to true to enable dashboard login
MFN_DASHBOARD_AUTH_ENABLED=false
MFN_DASHBOARD_USERNAME=admin
# Generate password hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
MFN_DASHBOARD_PASSWORD_HASH=

# JWT Secret for API authentication (if enabled)
# Generate: openssl rand -hex 32
JWT_SECRET=generate-random-secret-here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database path (default is relative)
DATABASE_URL=sqlite:///app/data/mfn_memories.db

# Database credentials for future PostgreSQL migration
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mfn_production
# DB_USER=mfn_user
# DB_PASSWORD=changeme

# ============================================================================
# REDIS CONFIGURATION (for future caching/session management)
# ============================================================================

REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=changeme

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API rate limiting
MFN_RATE_LIMIT_REQUESTS=100
MFN_RATE_LIMIT_WINDOW=60

# API authentication (when enabled)
# API_KEY=generate-random-api-key-here

# ============================================================================
# TLS/SSL CONFIGURATION (production)
# ============================================================================

# Set to true to enable TLS
MFN_TLS_ENABLED=false
MFN_TLS_CERT_PATH=/app/config/certs/server.crt
MFN_TLS_KEY_PATH=/app/config/certs/server.key

# ============================================================================
# MONITORING & ALERTING
# ============================================================================

# Prometheus authentication (if enabled)
# PROMETHEUS_ADMIN_USER=admin
# PROMETHEUS_ADMIN_PASSWORD=changeme

# Alert webhook endpoints (comma-separated)
# ALERT_WEBHOOK_URLS=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# EXTERNAL SERVICE API KEYS (when integrated)
# ============================================================================

# OpenAI API Key (for future AI integrations)
# OPENAI_API_KEY=sk-...

# Sentry DSN (for error tracking)
# SENTRY_DSN=https://...@sentry.io/...

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

# S3 backup configuration (for production)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BACKUP_BUCKET=mfn-backups
# AWS_REGION=us-east-1

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================

MFN_ENV=development
MFN_LOG_LEVEL=info
MFN_DATA_DIR=/app/data
MFN_LOG_DIR=/app/logs
MFN_SOCKET_DIR=/app/sockets
MFN_BACKUP_DIR=/app/backups
MFN_CONFIG_DIR=/app/config

# ============================================================================
# NOTES
# ============================================================================
#
# Security Best Practices:
# 1. Use strong, randomly-generated passwords for all services
# 2. Rotate secrets regularly (at least every 90 days)
# 3. Use different secrets for development, staging, and production
# 4. Store production secrets in a secure secrets manager (e.g., HashiCorp Vault, AWS Secrets Manager)
# 5. Never commit .env files to version control
# 6. Limit access to .env files using file permissions: chmod 600 .env
# 7. Use environment-specific .env files (.env.development, .env.production)
#
# Secret Generation Commands:
# - Random password (32 chars): openssl rand -base64 32
# - Random hex string (64 chars): openssl rand -hex 32
# - UUID: uuidgen
# - bcrypt hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'password', bcrypt.gensalt()).decode())"
#
