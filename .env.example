# MFN Environment Configuration
# Copy to .env and adjust values. Never commit .env to version control.

# API Gateway
MFN_API_PORT=8080
MFN_DATA_DIR=/data/mfn/memory
MFN_CORS_ORIGINS=http://localhost:3000

# Monitoring (only needed if Prometheus/Grafana services are enabled)
GRAFANA_ADMIN_PASSWORD=
